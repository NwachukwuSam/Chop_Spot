# Local Development Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# MongoDB Atlas
SPRING_DATA_MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/delichops_db?retryWrites=true&w=majority

# Keycloak (will be generated after Keycloak setup)
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# For production deployment, use environment variables in Render dashboard
