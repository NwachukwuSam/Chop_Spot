# Production Environment Variables
# Copy this to .env.production and fill in actual values
# NEVER commit .env.production to git!

# ============================================
# KEYCLOAK CONFIGURATION
# ============================================
# Replace 'delichops.com' with YOUR actual domain
# If you don't have a domain yet, use your AWS public IP or EC2 DNS
KEYCLOAK_URL=https://auth.yourdomain.com
KEYCLOAK_HOSTNAME=auth.yourdomain.com
# Get this from Keycloak admin console after creating the client
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_AFTER_KEYCLOAK_SETUP
KEYCLOAK_ADMIN_USERNAME=admin
# IMPORTANT: Change this to a strong password!
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ============================================
# POSTGRESQL (AWS RDS) - FOR KEYCLOAK ONLY
# ============================================
# You'll get this endpoint after creating RDS instance
# Format: your-db-name.xxxxx.region.rds.amazonaws.com
POSTGRES_URL=jdbc:postgresql://YOUR_RDS_ENDPOINT:5432/keycloak
POSTGRES_USERNAME=keycloak_admin
# IMPORTANT: Use a strong password (min 16 chars, mixed case, numbers, symbols)
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_DB_PASSWORD

# ============================================
# MONGODB ATLAS - YOUR EXISTING CONNECTION
# ============================================
# Use your EXISTING MongoDB Atlas connection string
# You already have: mongodb+srv://sales_book_db:jcjvfsDtGkwoM8z3@salesbook.nkan5iy.mongodb.net/
# For production, create a NEW database user with strong password
MONGODB_URI=mongodb+srv://sales_book_db:jcjvfsDtGkwoM8z3@salesbook.nkan5iy.mongodb.net/delichops_prod?retryWrites=true&w=majority

# ============================================
# SERVICE DISCOVERY (INTERNAL)
# ============================================
# This stays the same if using Docker Compose
# Change to AWS internal DNS if using ECS
EUREKA_URL=http://eureka-server:8761

# ============================================
# AWS CONFIGURATION (Optional - for AWS SDK)
# ============================================
AWS_REGION=us-east-1
# Only needed if your services directly access AWS services (S3, SES, etc.)
# Better to use IAM roles instead of access keys
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# MONITORING (Optional)
# ============================================
PROMETHEUS_ENABLED=true
GRAFANA_URL=https://monitoring.yourdomain.com
